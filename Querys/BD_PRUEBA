-- 12. Triggers para auditoría y actualización de stocks

-- Ejemplo de trigger para actualizar stock de materiales al registrar una compra
CREATE OR REPLACE FUNCTION actualizar_stock_material_compra()
RETURNS TRIGGER AS $$
BEGIN
    -- Actualizamos el stock del material
    UPDATE materiales
    SET stock_mat = stock_mat + NEW.cantidad,
        updated_at = CURRENT_TIMESTAMP
    WHERE id_mat = NEW.id_mat;
    
    -- Registramos el movimiento de inventario
    INSERT INTO movimientos_inventario (
        tipo_mov, id_mat, cantidad, stock_anterior, stock_posterior, id_comp, id_emp, motivo
    )
    SELECT 
        'ENTRADA', 
        NEW.id_mat, 
        NEW.cantidad, 
        m.stock_mat - NEW.cantidad, 
        m.stock_mat, 
        NEW.id_comp, 
        c.id_emp,
        'Compra de material'
    FROM materiales m, compras_materiales c
    WHERE m.id_mat = NEW.id_mat AND c.id_comp = NEW.id_comp;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_actualizar_stock_material_compra
AFTER INSERT ON detalles_compra
FOR EACH ROW
EXECUTE FUNCTION actualizar_stock_material_compra();

-- Ejemplo de trigger para actualizar stock de muebles al registrar una venta
CREATE OR REPLACE FUNCTION actualizar_stock_mueble_venta()
RETURNS TRIGGER AS $$
BEGIN
    -- Actualizamos el stock del mueble
    UPDATE muebles
    SET stock = stock - NEW.cantidad,
        updated_at = CURRENT_TIMESTAMP
    WHERE id_mue = NEW.id_mue;
    
    -- Registramos el movimiento de inventario
    INSERT INTO movimientos_inventario (
        tipo_mov, id_mue, cantidad, stock_anterior, stock_posterior, id_ven, id_emp, motivo
    )
    SELECT 
        'SALIDA', 
        NEW.id_mue, 
        NEW.cantidad, 
        m.stock + NEW.cantidad, 
        m.stock, 
        NEW.id_ven, 
        v.id_emp,
        'Venta de mueble'
    FROM muebles m, ventas v
    WHERE m.id_mue = NEW.id_mue AND v.id_ven = NEW.id_ven;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_actualizar_stock_mueble_venta
AFTER INSERT ON detalles_venta
FOR EACH ROW
EXECUTE FUNCTION actualizar_stock_mueble_venta();

-- Función para actualizar el campo updated_at en todas las tablas
CREATE OR REPLACE FUNCTION update_modified_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Aplicar el trigger a todas las tablas principales
CREATE TRIGGER trg_update_usuarios_modtime
BEFORE UPDATE ON usuarios
FOR EACH ROW
EXECUTE FUNCTION update_modified_column();

